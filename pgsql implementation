-- Function 5: Calculate Member Attendance Score
CREATE OR REPLACE FUNCTION calculate_attendance_score(
    p_member_id INTEGER,
    p_days INTEGER DEFAULT 30
) RETURNS DECIMAL AS $$
DECLARE
    v_attendance_count INTEGER;
    v_score DECIMAL;
BEGIN
    -- Count attendance in last N days
    SELECT COUNT(*) INTO v_attendance_count
    FROM attendance
    WHERE member_id = p_member_id
        AND date >= CURRENT_DATE - (p_days || ' days')::INTERVAL;
    
    -- Score: 5 points per visit, max 100
    v_score := LEAST(v_attendance_count * 5, 100);
    
    RETURN v_score;
    
EXCEPTION
    WHEN OTHERS THEN
        RETURN 0;
END;
$$ LANGUAGE plpgsql;

