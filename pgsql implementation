-- ─────────────────────────────────────────
-- Trigger 1: Auto-calculate BMI on body metrics insert/update
-- ─────────────────────────────────────────
CREATE OR REPLACE FUNCTION trigger_calculate_bmi()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.weight_kg IS NOT NULL AND NEW.height_cm IS NOT NULL THEN
        NEW.bmi := calculate_bmi(NEW.weight_kg, NEW.height_cm);
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS auto_calculate_bmi ON member_body_metrics;
CREATE TRIGGER auto_calculate_bmi
    BEFORE INSERT OR UPDATE ON member_body_metrics
    FOR EACH ROW
    EXECUTE FUNCTION trigger_calculate_bmi();

