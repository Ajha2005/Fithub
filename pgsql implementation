-- ─────────────────────────────────────────
-- Function 2: Get Days Until Subscription Expiry
-- ─────────────────────────────────────────
CREATE OR REPLACE FUNCTION get_days_until_expiry(p_member_id INTEGER)
RETURNS INTEGER AS $$
DECLARE
    v_end_date DATE;
BEGIN
    SELECT MAX(end_date) INTO v_end_date
    FROM member_subscriptions
    WHERE member_id = p_member_id;

    IF v_end_date IS NULL THEN
        RETURN NULL;
    END IF;

    RETURN (v_end_date - CURRENT_DATE);

EXCEPTION
    WHEN OTHERS THEN
        RETURN NULL;
END;
$$ LANGUAGE plpgsql;

