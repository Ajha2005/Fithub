-- Function 1: Calculate BMI
CREATE OR REPLACE FUNCTION calculate_bmi(
    p_weight_kg DECIMAL,
    p_height_cm DECIMAL
) RETURNS DECIMAL AS $$
DECLARE
    v_bmi DECIMAL;
BEGIN
    -- Validate inputs
    IF p_height_cm IS NULL OR p_height_cm <= 0 THEN
        RETURN NULL;
    END IF;
    
    IF p_weight_kg IS NULL OR p_weight_kg <= 0 THEN
        RETURN NULL;
    END IF;
    
    -- Calculate BMI: weight(kg) / (height(m))^2
    v_bmi := p_weight_kg / POWER(p_height_cm / 100, 2);
    
    RETURN ROUND(v_bmi, 2);
    
EXCEPTION
    WHEN OTHERS THEN
        RAISE NOTICE 'Error calculating BMI: %', SQLERRM;
        RETURN NULL;
END;
$$ LANGUAGE plpgsql;

