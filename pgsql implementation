    FOR EACH ROW
    EXECUTE FUNCTION trigger_update_timestamp();


-- Trigger 3: Validate subscription dates
CREATE OR REPLACE FUNCTION trigger_validate_subscription()
RETURNS TRIGGER AS $$
BEGIN
    -- Check end date is after start date
    IF NEW.end_date <= NEW.start_date THEN
        RAISE EXCEPTION 'Subscription end date must be after start date';
    END IF;
    
    -- Check amount paid is not negative
    IF NEW.amount_paid < 0 THEN
        RAISE EXCEPTION 'Amount paid cannot be negative';
    END IF;
    
    -- Check if member exists and is not suspended
    IF NOT EXISTS (
        SELECT 1 FROM members 
        WHERE member_id = NEW.member_id 
        AND status != 'suspended'
    ) THEN
        RAISE EXCEPTION 'Cannot create subscription for suspended or non-existent member';
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS validate_subscription ON member_subscriptions;
CREATE TRIGGER validate_subscription
    BEFORE INSERT OR UPDATE ON member_subscriptions
    FOR EACH ROW
    EXECUTE FUNCTION trigger_validate_subscription();


-- Trigger 4: Validate attendance check-out time
CREATE OR REPLACE FUNCTION trigger_validate_attendance()
RETURNS TRIGGER AS $$
BEGIN
    -- Ensure check-out is after check-in
    IF NEW.check_out_time IS NOT NULL AND NEW.check_out_time <= NEW.check_in_time THEN
        RAISE EXCEPTION 'Check-out time must be after check-in time';
    END IF;
    
    -- Ensure attendance date matches check-in date
    IF NEW.date != DATE(NEW.check_in_time) THEN
        NEW.date := DATE(NEW.check_in_time);
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS validate_attendance ON attendance;
CREATE TRIGGER validate_attendance
    BEFORE INSERT OR UPDATE ON attendance
    FOR EACH ROW
    EXECUTE FUNCTION trigger_validate_attendance();


-- Trigger 5: Log when member status changes
CREATE OR REPLACE FUNCTION trigger_log_member_status_change()
RETURNS TRIGGER AS $$
BEGIN
    IF OLD.status IS DISTINCT FROM NEW.status THEN
        RAISE NOTICE 'Member % status changed from % to %', 
            NEW.member_id, OLD.status, NEW.status;
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS log_member_status_change ON members;
CREATE TRIGGER log_member_status_change
    AFTER UPDATE ON members
    FOR EACH ROW
    EXECUTE FUNCTION trigger_log_member_status_change();


-- Trigger 6: Prevent deletion of equipment with pending maintenance
CREATE OR REPLACE FUNCTION trigger_prevent_equipment_deletion()
RETURNS TRIGGER AS $$
DECLARE
    v_pending_maintenance INTEGER;
BEGIN
    -- Check for future maintenance
    SELECT COUNT(*) INTO v_pending_maintenance
    FROM equipment_maintenance
    WHERE equipment_id = OLD.equipment_id
      AND next_maintenance_date >= CURRENT_DATE;
    
    IF v_pending_maintenance > 0 THEN
        RAISE EXCEPTION 'Cannot delete equipment with pending maintenance. Please complete or cancel maintenance first.';
    END IF;
    
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS prevent_equipment_deletion ON equipment;
CREATE TRIGGER prevent_equipment_deletion
    BEFORE DELETE ON equipment
    FOR EACH ROW
    EXECUTE FUNCTION trigger_prevent_equipment_deletion();


