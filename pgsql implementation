-- Procedure 1: Update All Engagement Scores (Main Analytics Procedure)
CREATE OR REPLACE PROCEDURE update_all_engagement_scores()
LANGUAGE plpgsql AS $$
DECLARE
    member_rec RECORD;
    v_attendance_score DECIMAL;
    v_goal_score DECIMAL;
    v_overall_score DECIMAL;
    v_risk_level VARCHAR;
    v_count INTEGER := 0;
BEGIN
    -- Loop through all active members
    FOR member_rec IN 
        SELECT member_id FROM members WHERE status = 'active'
    LOOP
        -- Calculate attendance score
        v_attendance_score := calculate_attendance_score(member_rec.member_id, 30);
        
        -- Calculate goal progress score
        v_goal_score := calculate_goal_progress_score(member_rec.member_id);
        
        -- Calculate overall engagement score (weighted average)
        v_overall_score := ROUND((v_attendance_score * 0.6 + v_goal_score * 0.4), 2);
        
        -- Determine churn risk level
        v_risk_level := determine_churn_risk(v_overall_score);
        
        -- Insert or update engagement score
        INSERT INTO member_engagement_scores (
            member_id, 
            calculation_date,
            attendance_score,
            goal_progress_score,
            overall_engagement_score,
            churn_risk_level
        ) VALUES (
            member_rec.member_id,
            CURRENT_DATE,
            v_attendance_score,
            v_goal_score,
            v_overall_score,
            v_risk_level
        )
        ON CONFLICT (member_id, calculation_date) 
        DO UPDATE SET
            attendance_score = EXCLUDED.attendance_score,
            goal_progress_score = EXCLUDED.goal_progress_score,
            overall_engagement_score = EXCLUDED.overall_engagement_score,
            churn_risk_level = EXCLUDED.churn_risk_level,
            created_at = CURRENT_TIMESTAMP;
        
        v_count := v_count + 1;
    END LOOP;
    
    RAISE NOTICE 'Engagement scores updated for % active members', v_count;
    
EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error updating engagement scores: %', SQLERRM;
END;
$$;

