-- ─────────────────────────────────────────
-- Procedure 3: Member Check-in with Validation
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE member_checkin(
    p_member_id INTEGER,
    OUT success BOOLEAN,
    OUT message TEXT
)
LANGUAGE plpgsql AS $$
DECLARE
    v_member_status      VARCHAR;
    v_subscription_end   DATE;
    v_already_checked_in BOOLEAN;
BEGIN
    success := FALSE;

    -- Verify member exists
    SELECT status INTO v_member_status
    FROM   members
    WHERE  member_id = p_member_id;

    IF NOT FOUND THEN
        message := 'Member not found';
        RETURN;
    END IF;

    -- Verify member is active
    IF v_member_status != 'active' THEN
        message := 'Member status is ' || v_member_status || '. Cannot check-in.';
        RETURN;
    END IF;

    -- Verify subscription is valid
    SELECT MAX(end_date) INTO v_subscription_end
    FROM   member_subscriptions
    WHERE  member_id = p_member_id;

    IF v_subscription_end IS NULL OR v_subscription_end < CURRENT_DATE THEN
        message := 'Subscription expired or missing. Please renew.';
        RETURN;
    END IF;

    -- Prevent duplicate check-in on same day
    SELECT EXISTS (
        SELECT 1 FROM attendance
        WHERE  member_id      = p_member_id
          AND  date           = CURRENT_DATE
          AND  check_out_time IS NULL
    ) INTO v_already_checked_in;

    IF v_already_checked_in THEN
        message := 'Member is already checked in today';
        RETURN;
    END IF;

    -- Record check-in
    INSERT INTO attendance (member_id, check_in_time, date)
    VALUES (p_member_id, CURRENT_TIMESTAMP, CURRENT_DATE);

    success := TRUE;
    message := 'Check-in successful';

EXCEPTION
    WHEN OTHERS THEN
        success := FALSE;
        message := 'Error during check-in: ' || SQLERRM;
END;
$$;

