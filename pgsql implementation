-- Function 2: Get Member Engagement Level
CREATE OR REPLACE FUNCTION get_engagement_level(p_member_id INTEGER)
RETURNS VARCHAR AS $$
DECLARE
    v_score DECIMAL;
BEGIN
    -- Get latest engagement score
    SELECT overall_engagement_score INTO v_score
    FROM member_engagement_scores
    WHERE member_id = p_member_id
    ORDER BY calculation_date DESC
    LIMIT 1;
    
    -- Return engagement level based on score
    IF v_score IS NULL THEN
        RETURN 'Unknown';
    ELSIF v_score >= 80 THEN
        RETURN 'Excellent';
    ELSIF v_score >= 60 THEN
        RETURN 'Good';
    ELSIF v_score >= 40 THEN
        RETURN 'Average';
    ELSIF v_score >= 20 THEN
        RETURN 'Low';
    ELSE
        RETURN 'Critical';
    END IF;
    
EXCEPTION
    WHEN OTHERS THEN
        RETURN 'Error';
END;
$$ LANGUAGE plpgsql;

