-- Function 6: Calculate Goal Progress Score
CREATE OR REPLACE FUNCTION calculate_goal_progress_score(p_member_id INTEGER)
RETURNS DECIMAL AS $$
DECLARE
    v_score DECIMAL;
BEGIN
    -- Calculate average goal achievement score
    SELECT COALESCE(AVG(
        CASE 
            WHEN status = 'achieved' THEN 100
            WHEN status = 'in_progress' THEN 60
            WHEN status = 'abandoned' THEN 20
            ELSE 0
        END
    ), 50) INTO v_score
    FROM member_fitness_goals
    WHERE member_id = p_member_id;
    
    RETURN ROUND(v_score, 2);
    
EXCEPTION
    WHEN OTHERS THEN
        RETURN 50;
END;
$$ LANGUAGE plpgsql;

