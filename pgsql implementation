-- ─────────────────────────────────────────
-- Procedure 5: Register New Member with Subscription
-- Full transaction: inserts member + subscription atomically
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE register_new_member(
    p_first_name    VARCHAR,
    p_last_name     VARCHAR,
    p_email         VARCHAR,
    p_phone         VARCHAR,
    p_plan_id       INTEGER,
    OUT new_member_id INTEGER,
    OUT success       BOOLEAN,
    OUT message       TEXT
)
LANGUAGE plpgsql AS $$
DECLARE
    v_plan_price    DECIMAL;
    v_plan_duration INTEGER;
BEGIN
    success := FALSE;

    BEGIN
        -- Check for duplicate email
        IF EXISTS (SELECT 1 FROM members WHERE email = p_email) THEN
            message := 'Email already registered';
            RETURN;
        END IF;

        -- Fetch plan details
        SELECT price, duration_months
        INTO   v_plan_price, v_plan_duration
        FROM   membership_plans
        WHERE  plan_id = p_plan_id AND is_active = TRUE;

        IF NOT FOUND THEN
            message := 'Invalid or inactive membership plan';
            RETURN;
        END IF;

        -- Insert member record
        INSERT INTO members (first_name, last_name, email, phone, status)
        VALUES (p_first_name, p_last_name, p_email, p_phone, 'active')
        RETURNING member_id INTO new_member_id;

        -- Insert subscription record
        INSERT INTO member_subscriptions
            (member_id, plan_id, start_date, end_date, amount_paid, payment_status)
        VALUES (
            new_member_id,
            p_plan_id,
            CURRENT_DATE,
            CURRENT_DATE + (v_plan_duration || ' months')::INTERVAL,
            v_plan_price,
            'completed'
        );

        success := TRUE;
        message := 'Member registered successfully. Member ID: ' || new_member_id;

    EXCEPTION
        WHEN OTHERS THEN
            success := FALSE;
            message := 'Registration failed: ' || SQLERRM;
            RAISE;
    END;
END;
$$;

