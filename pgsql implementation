-- ─────────────────────────────────────────
-- Function 6: Get Equipment Maintenance Status
-- ─────────────────────────────────────────
CREATE OR REPLACE FUNCTION get_equipment_status(p_equipment_id INTEGER)
RETURNS VARCHAR AS $$
DECLARE
    v_next_maintenance DATE;
BEGIN
    SELECT next_maintenance_date INTO v_next_maintenance
    FROM equipment_maintenance
    WHERE equipment_id = p_equipment_id
    ORDER BY maintenance_date DESC
    LIMIT 1;

    IF v_next_maintenance IS NULL THEN
        RETURN 'No Maintenance Scheduled';
    ELSIF v_next_maintenance < CURRENT_DATE THEN
        RETURN 'Overdue';
    ELSIF v_next_maintenance <= CURRENT_DATE + INTERVAL '7 days' THEN
        RETURN 'Due Soon';
    ELSIF v_next_maintenance <= CURRENT_DATE + INTERVAL '30 days' THEN
        RETURN 'Upcoming';
    ELSE
        RETURN 'Scheduled';
    END IF;

EXCEPTION
    WHEN OTHERS THEN
        RETURN 'Error';
END;
$$ LANGUAGE plpgsql;

