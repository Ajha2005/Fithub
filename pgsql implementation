-- Procedure with Cursor: Generate Member Activity Report
CREATE OR REPLACE PROCEDURE generate_member_activity_report()
LANGUAGE plpgsql AS $$
DECLARE
    member_cursor CURSOR FOR 
        SELECT m.member_id, m.first_name, m.last_name, m.email, m.status
        FROM members m
        WHERE m.status = 'active'
        ORDER BY m.member_id;
    
    member_rec RECORD;
    v_visits_30_days INTEGER;
    v_total_goals INTEGER;
    v_achieved_goals INTEGER;
    v_subscription_days INTEGER;
BEGIN
    RAISE NOTICE '========================================';
    RAISE NOTICE 'MEMBER ACTIVITY REPORT';
    RAISE NOTICE 'Generated: %', CURRENT_TIMESTAMP;
    RAISE NOTICE '========================================';
    
    OPEN member_cursor;
    
    LOOP
        FETCH member_cursor INTO member_rec;
        EXIT WHEN NOT FOUND;
        
        -- Get visits in last 30 days
        SELECT COUNT(*) INTO v_visits_30_days
        FROM attendance
        WHERE member_id = member_rec.member_id
          AND date >= CURRENT_DATE - INTERVAL '30 days';
        
        -- Get goal statistics
        SELECT 
            COUNT(*),
            COUNT(CASE WHEN status = 'achieved' THEN 1 END)
        INTO v_total_goals, v_achieved_goals
        FROM member_fitness_goals
        WHERE member_id = member_rec.member_id;
        
        -- Get subscription days remaining
        v_subscription_days := get_days_until_expiry(member_rec.member_id);
        
        RAISE NOTICE 'ID: % | Name: % % | Visits(30d): % | Goals: %/% | Sub Days: %',
            member_rec.member_id,
            member_rec.first_name,
            member_rec.last_name,
            v_visits_30_days,
            v_achieved_goals,
            v_total_goals,
            COALESCE(v_subscription_days::TEXT, 'N/A');
    END LOOP;
    
    CLOSE member_cursor;
    
    RAISE NOTICE '========================================';
    RAISE NOTICE 'Report Complete';
    RAISE NOTICE '========================================';
    
EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error generating report: %', SQLERRM;
END;
$$;

