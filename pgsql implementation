-- Function 7: Determine Churn Risk Level
CREATE OR REPLACE FUNCTION determine_churn_risk(p_engagement_score DECIMAL)
RETURNS VARCHAR AS $$
BEGIN
    IF p_engagement_score IS NULL THEN
        RETURN 'unknown';
    ELSIF p_engagement_score >= 70 THEN
        RETURN 'low';
    ELSIF p_engagement_score >= 50 THEN
        RETURN 'medium';
    ELSIF p_engagement_score >= 30 THEN
        RETURN 'high';
    ELSE
        RETURN 'critical';
    END IF;
END;
$$ LANGUAGE plpgsql;

