-- Procedure 6: Schedule Equipment Maintenance
CREATE OR REPLACE PROCEDURE schedule_equipment_maintenance(
    p_equipment_id INTEGER,
    p_maintenance_type VARCHAR,
    p_description TEXT,
    p_scheduled_date DATE,
    OUT success BOOLEAN,
    OUT message TEXT
)
LANGUAGE plpgsql AS $$
DECLARE
    v_equipment_status VARCHAR;
BEGIN
    success := FALSE;
    
    -- Check if equipment exists
    SELECT status INTO v_equipment_status
    FROM equipment
    WHERE equipment_id = p_equipment_id;
    
    IF NOT FOUND THEN
        message := 'Equipment not found';
        RETURN;
    END IF;
    
    -- Insert maintenance record
    INSERT INTO equipment_maintenance (
        equipment_id,
        maintenance_date,
        maintenance_type,
        description,
        next_maintenance_date
    ) VALUES (
        p_equipment_id,
        p_scheduled_date,
        p_maintenance_type,
        p_description,
        p_scheduled_date + INTERVAL '3 months'  -- Default next maintenance in 3 months
    );
    
    -- Update equipment status if maintenance is today or past
    IF p_scheduled_date <= CURRENT_DATE THEN
        UPDATE equipment
        SET status = 'maintenance'
        WHERE equipment_id = p_equipment_id;
    END IF;
    
    success := TRUE;
    message := 'Maintenance scheduled successfully';
    
EXCEPTION
    WHEN OTHERS THEN
        success := FALSE;
        message := 'Error scheduling maintenance: ' || SQLERRM;
END;
$$;


