-- Function 4: Get Member Status Summary
CREATE OR REPLACE FUNCTION get_member_status(p_member_id INTEGER)
RETURNS TABLE (
    member_name VARCHAR,
    subscription_status VARCHAR,
    days_remaining INTEGER,
    total_visits INTEGER,
    engagement_level VARCHAR
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        m.first_name || ' ' || m.last_name AS member_name,
        CASE 
            WHEN MAX(ms.end_date) >= CURRENT_DATE THEN 'Active'
            WHEN MAX(ms.end_date) >= CURRENT_DATE - INTERVAL '30 days' THEN 'Recently Expired'
            ELSE 'Expired'
        END AS subscription_status,
        get_days_until_expiry(p_member_id) AS days_remaining,
        COUNT(DISTINCT a.attendance_id)::INTEGER AS total_visits,
        get_engagement_level(p_member_id) AS engagement_level
    FROM members m
    LEFT JOIN member_subscriptions ms ON m.member_id = ms.member_id
    LEFT JOIN attendance a ON m.member_id = a.member_id 
        AND a.date >= CURRENT_DATE - INTERVAL '30 days'
    WHERE m.member_id = p_member_id
    GROUP BY m.member_id, m.first_name, m.last_name;
END;
$$ LANGUAGE plpgsql;

