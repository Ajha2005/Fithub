-- ─────────────────────────────────────────
-- Function 4: Calculate Member Attendance Score (last N days)
-- ─────────────────────────────────────────
CREATE OR REPLACE FUNCTION calculate_attendance_score(
    p_member_id INTEGER,
    p_days      INTEGER DEFAULT 30
)
RETURNS DECIMAL AS $$
DECLARE
    v_count INTEGER;
BEGIN
    SELECT COUNT(*) INTO v_count
    FROM attendance
    WHERE member_id = p_member_id
      AND date >= CURRENT_DATE - (p_days || ' days')::INTERVAL;

    -- 5 points per visit, capped at 100
    RETURN LEAST(v_count * 5, 100);

EXCEPTION
    WHEN OTHERS THEN
        RETURN 0;
END;
$$ LANGUAGE plpgsql;

