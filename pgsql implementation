-- ─────────────────────────────────────────
-- Procedure 1: Process Expired Subscriptions
-- Marks members with no active subscription as inactive
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE process_expired_subscriptions()
LANGUAGE plpgsql AS $$
DECLARE
    v_member_id     INTEGER;
    v_expired_count INTEGER := 0;
BEGIN
    FOR v_member_id IN (
        SELECT DISTINCT m.member_id
        FROM members m
        WHERE m.status = 'active'
          AND EXISTS (
              SELECT 1 FROM member_subscriptions ms
              WHERE ms.member_id = m.member_id
          )
          AND NOT EXISTS (
              SELECT 1 FROM member_subscriptions ms
              WHERE ms.member_id = m.member_id
                AND ms.end_date >= CURRENT_DATE
          )
    )
    LOOP
        UPDATE members
        SET    status     = 'inactive',
               updated_at = CURRENT_TIMESTAMP
        WHERE  member_id  = v_member_id;

        v_expired_count := v_expired_count + 1;
        RAISE NOTICE 'Member ID % marked inactive (subscription expired)', v_member_id;
    END LOOP;

    RAISE NOTICE 'Total members marked inactive: %', v_expired_count;

EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error processing expired subscriptions: %', SQLERRM;
END;
$$;

