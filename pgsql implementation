-- ─────────────────────────────────────────
-- Procedure: Clean Up Old Data
-- Removes records older than N months, keeping at least
-- the latest body metric record per member.
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE cleanup_old_data(p_months_old INTEGER DEFAULT 24)
LANGUAGE plpgsql AS $$
DECLARE
    v_deleted_attendance INTEGER;
    v_deleted_metrics    INTEGER;
BEGIN
    -- Remove old attendance records
    DELETE FROM attendance
    WHERE date < CURRENT_DATE - (p_months_old || ' months')::INTERVAL;
    GET DIAGNOSTICS v_deleted_attendance = ROW_COUNT;

    -- Remove old body metrics while preserving the most recent per member
    DELETE FROM member_body_metrics mbm
    WHERE measurement_date < CURRENT_DATE - (p_months_old || ' months')::INTERVAL
      AND EXISTS (
          SELECT 1 FROM member_body_metrics newer
          WHERE  newer.member_id        = mbm.member_id
            AND  newer.measurement_date > mbm.measurement_date
      );
    GET DIAGNOSTICS v_deleted_metrics = ROW_COUNT;

    RAISE NOTICE 'Cleanup complete:';
    RAISE NOTICE '  Deleted % old attendance record(s)',   v_deleted_attendance;
    RAISE NOTICE '  Deleted % old body metric record(s)',  v_deleted_metrics;

EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error during cleanup: %', SQLERRM;
END;
$$;

