-- ─────────────────────────────────────────
-- Procedure 4: Member Check-out
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE member_checkout(
    p_member_id INTEGER,
    OUT success BOOLEAN,
    OUT message TEXT
)
LANGUAGE plpgsql AS $$
DECLARE
    v_attendance_id INTEGER;
BEGIN
    success := FALSE;

    -- Find today's open check-in
    SELECT attendance_id INTO v_attendance_id
    FROM   attendance
    WHERE  member_id      = p_member_id
      AND  date           = CURRENT_DATE
      AND  check_out_time IS NULL
    ORDER  BY check_in_time DESC
    LIMIT  1;

    IF NOT FOUND THEN
        message := 'No active check-in found for today';
        RETURN;
    END IF;

    -- Record check-out
    UPDATE attendance
    SET    check_out_time = CURRENT_TIMESTAMP
    WHERE  attendance_id  = v_attendance_id;

    success := TRUE;
    message := 'Check-out successful';

EXCEPTION
    WHEN OTHERS THEN
        success := FALSE;
        message := 'Error during check-out: ' || SQLERRM;
END;
$$;

