-- ─────────────────────────────────────────
-- Procedure: Generate Member Activity Report (uses explicit cursor)
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE generate_member_activity_report()
LANGUAGE plpgsql AS $$
DECLARE
    member_cursor CURSOR FOR
        SELECT member_id, first_name, last_name, email, status
        FROM   members
        WHERE  status = 'active'
        ORDER  BY member_id;

    member_rec        RECORD;
    v_visits_30d      INTEGER;
    v_total_goals     INTEGER;
    v_achieved_goals  INTEGER;
    v_days_remaining  INTEGER;
BEGIN
    RAISE NOTICE '========================================';
    RAISE NOTICE 'MEMBER ACTIVITY REPORT';
    RAISE NOTICE 'Generated: %', CURRENT_TIMESTAMP;
    RAISE NOTICE '========================================';

    OPEN member_cursor;

    LOOP
        FETCH member_cursor INTO member_rec;
        EXIT WHEN NOT FOUND;

        -- Visits in last 30 days
        SELECT COUNT(*) INTO v_visits_30d
        FROM   attendance
        WHERE  member_id = member_rec.member_id
          AND  date >= CURRENT_DATE - INTERVAL '30 days';

        -- Goal statistics
        SELECT COUNT(*),
               COUNT(CASE WHEN status = 'achieved' THEN 1 END)
        INTO   v_total_goals, v_achieved_goals
        FROM   member_fitness_goals
        WHERE  member_id = member_rec.member_id;

        -- Days until subscription expiry
        v_days_remaining := get_days_until_expiry(member_rec.member_id);

        RAISE NOTICE 'ID: % | Name: % % | Visits(30d): % | Goals: %/% | Sub Days Left: %',
            member_rec.member_id,
            member_rec.first_name,
            member_rec.last_name,
            v_visits_30d,
            v_achieved_goals,
            v_total_goals,
            COALESCE(v_days_remaining::TEXT, 'N/A');
    END LOOP;

    CLOSE member_cursor;

    RAISE NOTICE '========================================';
    RAISE NOTICE 'Report Complete';
    RAISE NOTICE '========================================';

EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error generating report: %', SQLERRM;
END;
$$;

