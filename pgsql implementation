-- ─────────────────────────────────────────
-- Procedure 2: Generate Monthly Revenue Report
-- ─────────────────────────────────────────
CREATE OR REPLACE PROCEDURE generate_monthly_revenue_report(
    p_year  INTEGER,
    p_month INTEGER
)
LANGUAGE plpgsql AS $$
DECLARE
    v_total_revenue       DECIMAL;
    v_total_subscriptions INTEGER;
    v_avg_subscription    DECIMAL;
    plan_rec              RECORD;
BEGIN
    SELECT COUNT(*),
           SUM(amount_paid),
           AVG(amount_paid)
    INTO   v_total_subscriptions, v_total_revenue, v_avg_subscription
    FROM   member_subscriptions
    WHERE  EXTRACT(YEAR  FROM start_date) = p_year
      AND  EXTRACT(MONTH FROM start_date) = p_month
      AND  payment_status = 'completed';

    RAISE NOTICE '========================================';
    RAISE NOTICE 'MONTHLY REVENUE REPORT  -  %-% ',
        p_year, LPAD(p_month::TEXT, 2, '0');
    RAISE NOTICE '========================================';
    RAISE NOTICE 'Total Subscriptions       : %', v_total_subscriptions;
    RAISE NOTICE 'Total Revenue             : Rs.%', v_total_revenue;
    RAISE NOTICE 'Average Subscription Value: Rs.%', ROUND(v_avg_subscription, 2);
    RAISE NOTICE '========================================';
    RAISE NOTICE 'REVENUE BY PLAN:';
    RAISE NOTICE '========================================';

    FOR plan_rec IN (
        SELECT
            mp.plan_name,
            COUNT(ms.subscription_id)   AS sub_count,
            SUM(ms.amount_paid)         AS plan_revenue
        FROM membership_plans mp
        LEFT JOIN member_subscriptions ms
               ON mp.plan_id = ms.plan_id
              AND EXTRACT(YEAR  FROM ms.start_date) = p_year
              AND EXTRACT(MONTH FROM ms.start_date) = p_month
              AND ms.payment_status = 'completed'
        GROUP  BY mp.plan_id, mp.plan_name
        HAVING COUNT(ms.subscription_id) > 0
        ORDER  BY plan_revenue DESC
    )
    LOOP
        RAISE NOTICE '% : % subscriptions, Rs.%',
            RPAD(plan_rec.plan_name, 25),
            plan_rec.sub_count,
            plan_rec.plan_revenue;
    END LOOP;

    RAISE NOTICE '========================================';

EXCEPTION
    WHEN OTHERS THEN
        RAISE EXCEPTION 'Error generating report: %', SQLERRM;
END;
$$;

