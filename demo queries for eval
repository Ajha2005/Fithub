-- SECTION F: VIEWS DEMO
-- ============================================================


-- F1. Query the active_members_view — see all active members with plan info
SELECT * FROM active_members_view
ORDER  BY days_remaining ASC;

-- F2. Filter from view — only members whose subscription has expired
SELECT member_id, first_name, last_name,
       plan_name, end_date, days_remaining
FROM   active_members_view
WHERE  subscription_status = 'Expired'
ORDER  BY end_date;

-- F3. Query equipment_maintenance_view — overdue and due-soon equipment
SELECT equipment_name, category, brand, status,
       last_maintenance, next_maintenance_date, maintenance_status
FROM   equipment_maintenance_view
WHERE  maintenance_status IN ('Overdue', 'Due Soon')
ORDER  BY maintenance_status, next_maintenance_date;

-- F4. Full equipment maintenance view ordered by status urgency
SELECT equipment_name, status AS equip_status,
       maintenance_status, next_maintenance_date,
       last_maintenance_cost
FROM   equipment_maintenance_view
ORDER  BY
    CASE maintenance_status
        WHEN 'Overdue'   THEN 1
        WHEN 'Due Soon'  THEN 2
        WHEN 'Upcoming'  THEN 3
        ELSE                  4
    END,
    next_maintenance_date;

-- F5. Query member_progress_view — members who lost weight
SELECT first_name, last_name,
       measurement_date, weight_kg,
       previous_weight, weight_change,
       bmi, body_fat_percentage
FROM   member_progress_view
WHERE  weight_change < 0
ORDER  BY weight_change ASC;

-- F6. Best performers — highest weight loss from progress view
SELECT first_name, last_name,
       MIN(weight_change)   AS max_loss_in_one_period,
       SUM(weight_change)   AS net_weight_change,
       total_goals,
       achieved_goals
FROM   member_progress_view
GROUP  BY member_id, first_name, last_name,
          total_goals, achieved_goals
HAVING MIN(weight_change) IS NOT NULL
ORDER  BY net_weight_change ASC;


