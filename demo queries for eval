-- K1. "Show me members who have NEVER visited the gym"
SELECT m.member_id, m.first_name, m.last_name,
       m.registration_date, m.status
FROM   members m
WHERE  NOT EXISTS (
    SELECT 1 FROM attendance a
    WHERE  a.member_id = m.member_id
)
ORDER  BY m.registration_date;

-- K2. "Which plan generates the most revenue?"
SELECT mp.plan_name,
       SUM(ms.amount_paid)          AS total_revenue,
       COUNT(ms.subscription_id)    AS total_subs
FROM   membership_plans mp
JOIN   member_subscriptions ms ON mp.plan_id = ms.plan_id
WHERE  ms.payment_status = 'completed'
GROUP  BY mp.plan_id, mp.plan_name
ORDER  BY total_revenue DESC
LIMIT  1;

-- K3. "Find members who have achieved ALL their fitness goals"
SELECT m.first_name, m.last_name,
       COUNT(mfg.goal_id) AS total_goals
FROM   members m
JOIN   member_fitness_goals mfg ON m.member_id = mfg.member_id
GROUP  BY m.member_id, m.first_name, m.last_name
HAVING COUNT(mfg.goal_id) > 0
   AND COUNT(mfg.goal_id) = COUNT(CASE WHEN mfg.status = 'achieved' THEN 1 END)
ORDER  BY total_goals DESC;

-- K4. "What is the peak hour for gym check-ins?"
SELECT EXTRACT(HOUR FROM check_in_time)::INTEGER AS hour,
       COUNT(*)                                  AS checkins,
       REPEAT('█', COUNT(*)::INTEGER / 2)        AS bar_chart
FROM   attendance
GROUP  BY EXTRACT(HOUR FROM check_in_time)
ORDER  BY hour;

-- K5. "Show members whose BMI is in the 'Obese' range (BMI > 30)"
SELECT m.first_name, m.last_name, m.gender,
       mbm.weight_kg, mbm.height_cm, mbm.bmi,
       CASE
           WHEN mbm.bmi < 18.5 THEN 'Underweight'
           WHEN mbm.bmi < 25.0 THEN 'Normal'
           WHEN mbm.bmi < 30.0 THEN 'Overweight'
           ELSE 'Obese'
       END AS bmi_category,
       mbm.measurement_date
FROM   members m
JOIN   member_body_metrics mbm ON m.member_id = mbm.member_id
WHERE  mbm.bmi >= 25
  AND  mbm.measurement_date = (
           SELECT MAX(measurement_date)
           FROM   member_body_metrics
           WHERE  member_id = m.member_id
       )
ORDER  BY mbm.bmi DESC;
-- K6. "Which equipment has NEVER been maintained?"
SELECT e.equipment_id, e.equipment_name,
       e.category, e.purchase_date, e.status
FROM   equipment e
WHERE  NOT EXISTS (
    SELECT 1 FROM equipment_maintenance em
    WHERE  em.equipment_id = e.equipment_id
)
  AND  e.status != 'retired'
ORDER  BY e.purchase_date;

-- K7. "How many members registered each month? (trend analysis)"
SELECT TO_CHAR(registration_date, 'YYYY-MM') AS month,
       COUNT(*)                              AS new_members,
       SUM(COUNT(*)) OVER (ORDER BY TO_CHAR(registration_date, 'YYYY-MM'))
           AS cumulative_members
FROM   members
GROUP  BY TO_CHAR(registration_date, 'YYYY-MM')
ORDER  BY month;

-- K8. "Show the longest gym session (time spent inside) per member"
SELECT m.first_name, m.last_name,
       MAX(check_out_time - check_in_time) AS longest_session,
       AVG(check_out_time - check_in_time) AS avg_session
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
WHERE  a.check_out_time IS NOT NULL
GROUP  BY m.member_id, m.first_name, m.last_name
ORDER  BY longest_session DESC
LIMIT  10;

-- K9. "What is the retention rate? (members who renewed their subscription)"
SELECT COUNT(DISTINCT member_id)                     AS members_with_multiple_subs,
       (SELECT COUNT(*) FROM members WHERE status = 'active') AS total_active,
       ROUND(
           COUNT(DISTINCT member_id) * 100.0 /
           NULLIF((SELECT COUNT(*) FROM members WHERE status = 'active'), 0),
           1
       )                                              AS retention_pct
FROM (
    SELECT member_id
    FROM   member_subscriptions
    GROUP  BY member_id
    HAVING COUNT(*) > 1
) renewed;

-- K10. "Which members have a subscription expiring this month?"
SELECT m.first_name, m.last_name, m.email, m.phone,
       ms.end_date,
       mp.plan_name
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
JOIN   membership_plans     mp ON ms.plan_id  = mp.plan_id
WHERE  DATE_TRUNC('month', ms.end_date) = DATE_TRUNC('month', CURRENT_DATE)
  AND  ms.end_date = (
           SELECT MAX(end_date) FROM member_subscriptions
           WHERE  member_id = m.member_id
       )
ORDER  BY ms.end_date;

-- K11. "Difference between 3NF and BCNF" (demonstrate with schema)
--      Show that no transitive dependencies exist
SELECT table_name, column_name, data_type
FROM   information_schema.columns
WHERE  table_schema = 'public'
  AND  table_name IN ('members','member_subscriptions','membership_plans')
ORDER  BY table_name, ordinal_position;

-- K12. "Show all foreign key relationships in the database"
SELECT
    tc.table_name        AS child_table,
    kcu.column_name      AS child_column,
    ccu.table_name       AS parent_table,
    ccu.column_name      AS parent_column,
    rc.delete_rule       AS on_delete
FROM information_schema.table_constraints       tc
JOIN information_schema.key_column_usage        kcu ON tc.constraint_name  = kcu.constraint_name
JOIN information_schema.constraint_column_usage ccu ON tc.constraint_name  = ccu.constraint_name
JOIN information_schema.referential_constraints rc  ON tc.constraint_name  = rc.constraint_name
WHERE tc.constraint_type = 'FOREIGN KEY'
  AND tc.table_schema    = 'public'
ORDER BY child_table;

-- K13. "Show all CHECK constraints in the schema"
SELECT tc.table_name,
       tc.constraint_name,
       cc.check_clause
FROM   information_schema.table_constraints      tc
JOIN   information_schema.check_constraints      cc
       ON tc.constraint_name = cc.constraint_name
WHERE  tc.table_schema = 'public'
  AND  tc.constraint_type = 'CHECK'
ORDER  BY tc.table_name;

-- K14. "What is the total value of all gym equipment?"
SELECT COUNT(*)                                      AS total_units,
       SUM(purchase_price)                           AS total_investment,
       ROUND(AVG(purchase_price), 2)                 AS avg_unit_price,
       MAX(purchase_price)                           AS most_expensive,
       MIN(purchase_price)                           AS least_expensive
FROM   equipment
WHERE  status != 'retired';

-- K15. "Members currently inside the gym right now (not checked out)"
SELECT m.first_name, m.last_name,
       a.check_in_time,
       CURRENT_TIMESTAMP - a.check_in_time AS time_inside
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
WHERE  a.check_out_time IS NULL
  AND  a.date = CURRENT_DATE
ORDER  BY a.check_in_time;

