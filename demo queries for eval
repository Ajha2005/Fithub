-- ============================================================
-- SECTION A: BASIC SELECT, FILTERING & SORTING
-- ============================================================

-- A1. List all active members with their basic info
SELECT member_id, first_name, last_name, email, phone,
       gender, registration_date, status
FROM   members
WHERE  status = 'active'
ORDER  BY registration_date DESC;

-- A2. Members registered in 2025
SELECT first_name, last_name, email, registration_date
FROM   members
WHERE  registration_date BETWEEN '2025-01-01' AND '2025-12-31'
ORDER  BY registration_date;

-- A3. Female members who are active
SELECT first_name, last_name, email, date_of_birth
FROM   members
WHERE  gender = 'Female' AND status = 'active'
ORDER  BY last_name;

-- A4. All membership plans sorted by price
SELECT plan_id, plan_name, duration_months,
       price, facilities_included, is_active
FROM   membership_plans
ORDER  BY price;

-- A5. Equipment currently under maintenance or out of order
SELECT equipment_id, equipment_name, category, brand, location, status
FROM   equipment
WHERE  status IN ('maintenance', 'out_of_order')
ORDER  BY status, equipment_name;

-- A6. Members whose subscription was paid via UPI
SELECT m.first_name, m.last_name, ms.amount_paid,
       ms.payment_method, ms.start_date, ms.end_date
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
WHERE  ms.payment_method = 'upi'
ORDER  BY ms.start_date DESC;

-- A7. Members with auto-renew enabled
SELECT m.first_name, m.last_name, mp.plan_name,
       ms.end_date, ms.auto_renew
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
JOIN   membership_plans     mp ON ms.plan_id  = mp.plan_id
WHERE  ms.auto_renew = TRUE
ORDER  BY ms.end_date;

-- ============================================================
-- SECTION B: AGGREGATE FUNCTIONS & GROUP BY
-- ============================================================

-- B1. Count of members by status
SELECT status, COUNT(*) AS member_count
FROM   members
GROUP  BY status
ORDER  BY member_count DESC;

-- B2. Total revenue collected per membership plan
SELECT mp.plan_name,
       COUNT(ms.subscription_id)        AS total_subscriptions,
       SUM(ms.amount_paid)              AS total_revenue,
       ROUND(AVG(ms.amount_paid), 2)    AS avg_amount
FROM   membership_plans mp
JOIN   member_subscriptions ms ON mp.plan_id = ms.plan_id
WHERE  ms.payment_status = 'completed'
GROUP  BY mp.plan_id, mp.plan_name
ORDER  BY total_revenue DESC;

-- B3. Monthly subscription revenue for 2025
SELECT EXTRACT(MONTH FROM start_date)::INTEGER AS month,
       TO_CHAR(start_date, 'Month')            AS month_name,
       COUNT(*)                                AS subscriptions,
       SUM(amount_paid)                        AS revenue
FROM   member_subscriptions
WHERE  EXTRACT(YEAR FROM start_date) = 2025
  AND  payment_status = 'completed'
GROUP  BY EXTRACT(MONTH FROM start_date), TO_CHAR(start_date, 'Month')
ORDER  BY month;

-- B4. Attendance count per member in March 2026 (top 10 most active)
SELECT m.first_name, m.last_name,
       COUNT(a.attendance_id) AS visits
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
WHERE  a.date BETWEEN '2026-03-01' AND '2026-03-31'
GROUP  BY m.member_id, m.first_name, m.last_name
ORDER  BY visits DESC
LIMIT  10;

-- B5. Equipment count by category
SELECT category,
       COUNT(*)                                  AS total_units,
       COUNT(CASE WHEN status = 'operational'    THEN 1 END) AS operational,
       COUNT(CASE WHEN status = 'maintenance'    THEN 1 END) AS under_maintenance,
       COUNT(CASE WHEN status = 'out_of_order'   THEN 1 END) AS out_of_order,
       COUNT(CASE WHEN status = 'retired'        THEN 1 END) AS retired
FROM   equipment
GROUP  BY category
ORDER  BY total_units DESC;

-- B6. Number of goals by type and status
SELECT goal_type, status, COUNT(*) AS count
FROM   member_fitness_goals
GROUP  BY goal_type, status
ORDER  BY goal_type, status;

-- B7. Total maintenance cost per equipment
SELECT e.equipment_name, e.brand,
       COUNT(em.maintenance_id)   AS maintenance_count,
       SUM(em.cost)               AS total_cost,
       MAX(em.maintenance_date)   AS last_serviced
FROM   equipment e
JOIN   equipment_maintenance em ON e.equipment_id = em.equipment_id
GROUP  BY e.equipment_id, e.equipment_name, e.brand
ORDER  BY total_cost DESC;

-- B8. Average body weight by gender (latest reading per member)
SELECT m.gender,
       ROUND(AVG(mbm.weight_kg), 2) AS avg_weight_kg,
       ROUND(AVG(mbm.bmi),       2) AS avg_bmi,
       COUNT(DISTINCT m.member_id)  AS members_tracked
FROM   members m
JOIN   member_body_metrics mbm ON m.member_id = mbm.member_id
WHERE  mbm.measurement_date = (
           SELECT MAX(measurement_date)
           FROM   member_body_metrics
           WHERE  member_id = m.member_id
       )
GROUP  BY m.gender;

-- ============================================================
-- SECTION C: JOINS
-- ============================================================

-- C1. INNER JOIN — Members with their current plan name
SELECT m.member_id, m.first_name, m.last_name,
       mp.plan_name, ms.start_date, ms.end_date,
       ms.amount_paid, ms.payment_status
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
JOIN   membership_plans     mp ON ms.plan_id  = mp.plan_id
ORDER  BY ms.end_date DESC;

-- C2. LEFT JOIN — Members who have NO fitness goals recorded
SELECT m.member_id, m.first_name, m.last_name, m.status
FROM   members m
LEFT   JOIN member_fitness_goals mfg ON m.member_id = mfg.member_id
WHERE  mfg.goal_id IS NULL
ORDER  BY m.member_id;

-- C3. LEFT JOIN — Members who have NO body metrics recorded
SELECT m.member_id, m.first_name, m.last_name
FROM   members m
LEFT   JOIN member_body_metrics mbm ON m.member_id = mbm.member_id
WHERE  mbm.metric_id IS NULL
ORDER  BY m.member_id;

-- C4. Multi-table JOIN — Full member snapshot
--     (member + subscription + plan + latest body metric)
SELECT m.first_name,
       m.last_name,
       mp.plan_name,
       ms.end_date             AS sub_expires,
       mbm.weight_kg,
       mbm.bmi,
       mbm.body_fat_percentage,
       mbm.measurement_date    AS last_measured
FROM   members m
JOIN   member_subscriptions ms  ON m.member_id   = ms.member_id
JOIN   membership_plans     mp  ON ms.plan_id     = mp.plan_id
LEFT   JOIN member_body_metrics mbm ON m.member_id = mbm.member_id
       AND mbm.measurement_date = (
           SELECT MAX(measurement_date)
           FROM   member_body_metrics
           WHERE  member_id = m.member_id
       )
WHERE  m.status = 'active'
ORDER  BY m.last_name;

-- C5. Equipment with its latest maintenance record (LATERAL JOIN)
SELECT e.equipment_id, e.equipment_name, e.status,
       em.maintenance_date     AS last_maintained,
       em.next_maintenance_date,
       em.maintenance_type,
       em.performed_by
FROM   equipment e
LEFT   JOIN LATERAL (
    SELECT * FROM equipment_maintenance
    WHERE  equipment_id = e.equipment_id
    ORDER  BY maintenance_date DESC
    LIMIT  1
) em ON TRUE
ORDER  BY e.equipment_id;

-- C6. Members with their attendance count and subscription status
SELECT m.first_name, m.last_name,
       COUNT(a.attendance_id)  AS total_visits,
       MAX(a.date)             AS last_visit,
       mp.plan_name,
       ms.end_date
FROM   members m
LEFT   JOIN attendance          a  ON m.member_id = a.member_id
JOIN         member_subscriptions ms ON m.member_id = ms.member_id
JOIN         membership_plans     mp ON ms.plan_id  = mp.plan_id
WHERE  m.status = 'active'
GROUP  BY m.member_id, m.first_name, m.last_name,
          mp.plan_name, ms.end_date
ORDER  BY total_visits DESC;

-- ============================================================
-- SECTION D: SUBQUERIES & CTEs
-- ============================================================

-- D1. Members whose subscription expires within the next 30 days
SELECT m.first_name, m.last_name, m.email, m.phone,
       ms.end_date,
       (ms.end_date - CURRENT_DATE) AS days_left
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
WHERE  ms.end_date = (
           SELECT MAX(end_date) FROM member_subscriptions
           WHERE  member_id = m.member_id
       )
  AND  ms.end_date BETWEEN CURRENT_DATE AND CURRENT_DATE + INTERVAL '30 days'
ORDER  BY ms.end_date;

-- D2. Members who have attended more than the average attendance
SELECT m.first_name, m.last_name,
       COUNT(a.attendance_id) AS visit_count
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
GROUP  BY m.member_id, m.first_name, m.last_name
HAVING COUNT(a.attendance_id) > (
    SELECT AVG(sub.visit_count)
    FROM (
        SELECT COUNT(attendance_id) AS visit_count
        FROM   attendance
        GROUP  BY member_id
    ) sub
)
ORDER  BY visit_count DESC;

-- D3. CTE — Revenue summary with running total
WITH monthly_revenue AS (
    SELECT DATE_TRUNC('month', start_date) AS month,
           SUM(amount_paid)                AS revenue
    FROM   member_subscriptions
    WHERE  payment_status = 'completed'
    GROUP  BY DATE_TRUNC('month', start_date)
)
SELECT TO_CHAR(month, 'Mon YYYY')                          AS month,
       revenue,
       SUM(revenue) OVER (ORDER BY month)                  AS running_total
FROM   monthly_revenue
ORDER  BY month;

-- D4. CTE — Members with their goal achievement rate
WITH goal_stats AS (
    SELECT member_id,
           COUNT(*)                                            AS total_goals,
           COUNT(CASE WHEN status = 'achieved' THEN 1 END)    AS achieved,
           COUNT(CASE WHEN status = 'abandoned' THEN 1 END)   AS abandoned
    FROM   member_fitness_goals
    GROUP  BY member_id
)
SELECT m.first_name, m.last_name,
       gs.total_goals,
       gs.achieved,
       gs.abandoned,
       ROUND(gs.achieved * 100.0 / NULLIF(gs.total_goals, 0), 1) AS achievement_pct
FROM   members m
JOIN   goal_stats gs ON m.member_id = gs.member_id
ORDER  BY achievement_pct DESC NULLS LAST;

-- D5. CTE — Equipment that is overdue for maintenance
WITH latest_maintenance AS (
    SELECT equipment_id,
           MAX(next_maintenance_date) AS next_due
    FROM   equipment_maintenance
    GROUP  BY equipment_id
)
SELECT e.equipment_id, e.equipment_name, e.category,
       e.location, lm.next_due,
       (CURRENT_DATE - lm.next_due) AS days_overdue
FROM   equipment e
JOIN   latest_maintenance lm ON e.equipment_id = lm.equipment_id
WHERE  lm.next_due < CURRENT_DATE
  AND  e.status    != 'retired'
ORDER  BY days_overdue DESC;

-- D6. Correlated subquery — Members whose latest weight is above
--     the average weight of all tracked members
SELECT m.first_name, m.last_name,
       latest.weight_kg,
       (SELECT ROUND(AVG(weight_kg), 2)
        FROM   member_body_metrics)  AS avg_weight
FROM   members m
JOIN   LATERAL (
    SELECT weight_kg
    FROM   member_body_metrics
    WHERE  member_id = m.member_id
    ORDER  BY measurement_date DESC
    LIMIT  1
) latest ON TRUE
WHERE  latest.weight_kg > (SELECT AVG(weight_kg) FROM member_body_metrics)
ORDER  BY latest.weight_kg DESC;

-- ============================================================
-- SECTION E: WINDOW FUNCTIONS
-- ============================================================

-- E1. Rank members by total attendance (RANK)
SELECT m.first_name, m.last_name,
       COUNT(a.attendance_id)                       AS visits,
       RANK() OVER (ORDER BY COUNT(a.attendance_id) DESC) AS rank
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
GROUP  BY m.member_id, m.first_name, m.last_name
ORDER  BY rank;

-- E2. Running total of revenue over time (SUM OVER)
SELECT start_date,
       amount_paid,
       SUM(amount_paid) OVER (ORDER BY start_date
                              ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
           AS running_revenue
FROM   member_subscriptions
WHERE  payment_status = 'completed'
ORDER  BY start_date;

-- E3. Weight change between consecutive measurements per member (LAG)
SELECT m.first_name, m.last_name,
       mbm.measurement_date,
       mbm.weight_kg,
       LAG(mbm.weight_kg) OVER (PARTITION BY mbm.member_id
                                ORDER BY mbm.measurement_date) AS prev_weight,
       ROUND(
           mbm.weight_kg -
           LAG(mbm.weight_kg) OVER (PARTITION BY mbm.member_id
                                    ORDER BY mbm.measurement_date),
           2
       )                          AS weight_change_kg
FROM   members m
JOIN   member_body_metrics mbm ON m.member_id = mbm.member_id
ORDER  BY mbm.member_id, mbm.measurement_date;

-- E4. Percentile rank of members by subscription amount (PERCENT_RANK)
SELECT m.first_name, m.last_name,
       ms.amount_paid,
       mp.plan_name,
       ROUND(CAST(PERCENT_RANK() OVER (ORDER BY ms.amount_paid) * 100 AS NUMERIC), 1) AS percentile
FROM   members m
JOIN   member_subscriptions ms ON m.member_id = ms.member_id
JOIN   membership_plans     mp ON ms.plan_id  = mp.plan_id
ORDER  BY ms.amount_paid DESC;



-- E5. Row number for each member's attendance entries (ROW_NUMBER)
SELECT m.first_name, m.last_name,
       a.date, a.check_in_time,
       ROW_NUMBER() OVER (PARTITION BY a.member_id
                          ORDER BY a.check_in_time) AS visit_number
FROM   members m
JOIN   attendance a ON m.member_id = a.member_id
ORDER  BY a.member_id, visit_number;

-- E6. Average weight within each gender group (AVG OVER PARTITION)
SELECT m.first_name, m.last_name, m.gender,
       mbm.weight_kg,
       ROUND(AVG(mbm.weight_kg) OVER (PARTITION BY m.gender), 2) AS gender_avg_weight,
       ROUND(mbm.weight_kg - AVG(mbm.weight_kg) OVER (PARTITION BY m.gender), 2) AS diff_from_avg
FROM   members m
JOIN   member_body_metrics mbm ON m.member_id = mbm.member_id
WHERE  mbm.measurement_date = (
           SELECT MAX(measurement_date) FROM member_body_metrics
           WHERE  member_id = m.member_id
       )
ORDER  BY m.gender, diff_from_avg DESC;


